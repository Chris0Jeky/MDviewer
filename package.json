{
  "name": "mdviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based, drag-and-drop Markdown to PDF viewer with page-break-safe pagination for research and code documents.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "agent:hooks:smoke": "python scripts/agent_hooks/smoke_test.py",
    "agent:skills:validate": "python scripts/agent_hooks/validate_skills.py",
    "agent:ledger:render": "python scripts/agent_hooks/render_failure_ledger.py",
    "agent:check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-toc-done-right": "^4.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-task-lists": "^2.1.1",
    "shiki": "^3.0.0",
    "@shikijs/core": "^3.0.0",
    "@shikijs/langs": "^3.0.0",
    "@shikijs/themes": "^3.0.0",
    "@shikijs/markdown-it": "^3.0.0",
    "@shikijs/transformers": "^3.0.0",
    "@vscode/markdown-it-katex": "^1.1.0",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "pagedjs": "^0.4.3",
    "jspdf": "^4.2.1",
    "html2canvas-pro": "^1.5.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "@types/katex": "^0.16.7",
    "@types/markdown-it": "^14.1.0",
    "@types/markdown-it-container": "^2.0.10",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
