{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(pwd)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git rebase --abort*)",
      "Bash(git rebase --continue*)",
      "Bash(git rebase --skip*)",
      "Bash(git merge --abort*)",
      "Bash(rg *)",
      "Bash(node*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run preview*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run test:e2e*)",
      "Bash(npm run agent:*)",
      "Bash(npx vitest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx playwright*)",
      "Bash(python scripts/agent_hooks/*.py*)",
      "Bash(python -m py_compile scripts/agent_hooks/*.py*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(Remove-Item * -Recurse * -Force*)",
      "Bash(Remove-Item * -Force * -Recurse*)",
      "Bash(sudo *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(iwr * | powershell*)",
      "Bash(irm * | iex*)",
      "Bash(npm publish*)",
      "Bash(*.env*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR\\scripts\\agent_hooks\\session_start.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR\\scripts\\agent_hooks\\pre_tool_use.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR\\scripts\\agent_hooks\\post_tool_use.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"$env:CLAUDE_PROJECT_DIR\\scripts\\agent_hooks\\post_tool_failure.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
